{
  "name": "iris",
  "version": "1.0.0",
  "description": "Threat intelligence aggregation and IOC correlation platform. Ingests feeds, deduplicates, scores, and exposes IOCs via API.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "feed:ingest": "tsx src/feeds/runner.ts",
    "db:init": "tsx src/db/init.ts",
    "lint": "tsc --noEmit",
    "test": "npx tsx --test tests/*.test.ts"
  },
  "keywords": [
    "threat-intelligence",
    "ioc",
    "security",
    "soc",
    "cti",
    "osint"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.0",
    "hono": "^4.7.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
